  "keyFeatures": [
    "C2B (Customer-to-Business) collections via STK push / USSD",
    "B2C (Business-to-Customer) payouts to mobile wallets and bank accounts",
    "Asynchronous transaction processing with webhook notifications",
    "Transaction status polling via retrievalReferenceNo",
    "Support for M-PESA, Airtel Money, and other African mobile money providers",
    "OAuth2 client credentials authentication",
    "Sandbox environment for testing",
    "Idempotent request handling via merchant transactionId"
  ],
  "publicApiSurface": [
    "POST /api/v1/c2b — Initiate a Customer-to-Business collection",
    "POST /api/v1/b2c — Initiate a Business-to-Customer payout",
    "GET /api/v1/transaction/{referenceId} — Get transaction status (public)",
    "POST /oauth/token — Obtain an OAuth2 bearer token",
    "Webhook: POST notificationUrl — Receive final transaction outcome"
  ]
}
